{
  "_comment": "Codex-native hook manifest for SuperTeam Codex. Hooks are guidance-first and delegate workflow state decisions to the Python runtime.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python \"./hooks/codex_hook.py\" SessionStart" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python \"./hooks/codex_hook.py\" UserPromptSubmit" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "python \"./hooks/codex_hook.py\" PreToolUse" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "python \"./hooks/codex_hook.py\" PostToolUse" }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          { "type": "command", "command": "python \"./hooks/codex_hook.py\" PermissionRequest" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python \"./hooks/codex_hook.py\" Stop" }
        ]
      }
    ]
  }
}
