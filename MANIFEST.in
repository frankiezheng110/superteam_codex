include README.md
include VERSION.md
include LICENSE
include AGENTS.md
include .codex-plugin/plugin.json

recursive-include docs *.md
recursive-include scripts *.ps1
recursive-include skills *.md
recursive-include superteam_codex *.py
recursive-include templates *.md
recursive-include tests *.py
recursive-include tests/fixtures *

recursive-exclude * __pycache__ *
recursive-exclude * *.py[cod]
recursive-exclude .superteam_codex *
recursive-exclude .hook-trace-tests *
recursive-exclude build *
recursive-exclude dist *
recursive-exclude *.egg-info *
